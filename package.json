{
  "name": "mastra-imessage-agent",
  "private": true,
  "type": "module",
  "module": "src/main.ts",
  "scripts": {
    "dev": "bun run --hot src/main.ts",
    "start": "bun run src/main.ts",
    "test:script": "bun run scripts/send-message.ts",
    "test": "vp test run",
    "test:unit": "vp test run tests/unit",
    "test:integration": "vp test run tests/integration",
    "test:e2e": "vp test run tests/e2e",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "fmt": "vp fmt",
    "fmt:check": "vp fmt --check",
    "check": "vp check",
    "tcheck": "vp check",
    "ci:prepush": "bun run check && bun run test",
    "prepare": "vp config"
  },
  "dependencies": {
    "@mastra/core": "^1.2.0",
    "@mastra/libsql": "^1.2.0",
    "@mastra/mcp": "^1.3.1",
    "@mastra/memory": "^1.2.0",
    "@photon-ai/imessage-kit": "^2.1.2",
    "@t3-oss/env-core": "^0.13.10",
    "consola": "^3.4.2",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.8.3",
    "vite-plus": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "packageManager": "bun@1.3.10"
}
